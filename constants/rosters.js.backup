    '7': { name: 'Minkah Fitzpatrick', position: 'S', era: 'Current', number: 39 },
    '6': { name: 'Cameron Heyward', position: 'DT', era: 'Current', number: 97 },
    '5': { name: 'Alex Highsmith', position: 'LB', era: 'Current', number: 56 },
    '4': { name: 'Joey Porter', position: 'LB', era: 'Legend', number: 55 },
    '3': { name: 'James Harrison', position: 'LB', era: 'Legend', number: 92 },
    '2': { name: 'Chris Boswell', position: 'K', era: 'Current', number: 9 }
  }
};

// ============================================
// TEAM ROSTERS COLLECTION
// ============================================

export const TEAM_ROSTERS = {
  'atl': ATLANTA_FALCONS,
  'kc': KANSAS_CITY_CHIEFS,
  'sf': SAN_FRANCISCO_49ERS,
  'pit': PITTSBURGH_STEELERS,
  // Add remaining 28 teams here following the same pattern
  // Each team needs 52 players (13 ranks × 4 suits)
};

// Helper functions
export const getAllTeams = () => NFL_TEAMS;

export const getTeamRoster = (teamId) => {
  return TEAM_ROSTERS[teamId] || null;
};

export const getTeamName = (teamId) => {
  const team = NFL_TEAMS.find(t => t.id === teamId);
  return team ? team.name : 'Unknown Team';
};

export const getTeamEmoji = (teamId) => {
  const team = NFL_TEAMS.find(t => t.id === teamId);
  return team ? team.emoji : '🏈';
};

export const getTeamPrimaryColor = (teamId) => {
  const team = NFL_TEAMS.find(t => t.id === teamId);
  return team ? team.primaryColor : '#0a3d0a';
};
